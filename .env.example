# SentinelFlow 平台最小运行配置示例

# 大模型配置
SENTINELFLOW_LLM_API_BASE_URL=https://api.openai.com/v1
SENTINELFLOW_LLM_API_KEY=
SENTINELFLOW_LLM_MODEL=
SENTINELFLOW_LLM_TEMPERATURE=0
SENTINELFLOW_LLM_TIMEOUT=60

# 平台运行配置
SENTINELFLOW_AGENT_ENABLED=true
SENTINELFLOW_POLL_INTERVAL_SECONDS=60
SENTINELFLOW_API_BASE_URL=http://127.0.0.1:8001

# 公开演示版建议默认开启 Demo Mode
SENTINELFLOW_DEMO_MODE=true
SENTINELFLOW_DEMO_FALLBACK=true
